// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Incident {
  id           Int       @id @default(autoincrement())
  url          String    @unique
  altSources   String?
  date         String?
  parsedDate   DateTime?
  location     String?
  latitude     Float?
  longitude    Float?
  headline     String?
  summary      String?
  incidentType String?
  country      String?
  imageUrl     String?
  status       String    @default("RAW")
  approved     Boolean   @default(false)
  reviewedA    Boolean   @default(false)
  reviewedJ    Boolean   @default(false)
  reviewedP    Boolean   @default(false)
  excludePoster Boolean  @default(false)
  timeline     String?
  rawHtml      String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([approved])
  @@index([parsedDate(sort: Desc), createdAt(sort: Desc)])
  @@index([status, approved, headline])
  @@index([country])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String?
  message   String
  createdAt DateTime @default(now())
}
